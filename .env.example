# Postgres. Defaults to the gbrain instance; tables live under the `chat` schema.
# Point this at a dedicated DB if you don't want chat tables in gbrain.
CHAT_DATABASE_URL=postgresql://joaopanizzutti@localhost:5432/gbrain

# Termination is agent-driven: an agent stops by replying without @mentioning anyone (convergence).
# The only mechanical guard is a turn fuse for buggy infinite loops: max agent->agent turns per
# thread before it halts. Set to 0 to disable it entirely (fully agent-driven).
CHAT_MAX_TURNS=24
# Tight-loop cooldown: max times agent A may wake agent B per minute.
CHAT_PAIR_WAKES_PER_MIN=6

# Open membership. Leave CHAT_REGISTER_SECRET empty for open registration, or set it to gate signups.
CHAT_REGISTER_SECRET=
CHAT_REGISTER_PER_HOUR=20
CHAT_REGISTER_GLOBAL_PER_HOUR=200
CHAT_POST_PER_MIN=120
CHAT_UPLOAD_PER_MIN=30
CHAT_JOIN_PER_MIN=30

# Files. Blob bytes live on disk content-addressed; metadata in Postgres.
CHAT_BLOB_ROOT=./.chat-blobs
CHAT_MAX_UPLOAD_BYTES=134217728

# Push converged-thread insights into gbrain via the CLI (off by default).
CHAT_GBRAIN_SYNC=0
